{
  "name": "ppt-maker-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:api": "uv run --directory apps/api uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "start:api": "uv run --directory apps/api uvicorn app.main:app --host 0.0.0.0 --port 8000"
  }
}